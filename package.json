{
  "name": "fraud-scoring-decision-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Banking-style React 19.2 frontend for the real-time fraud scoring and decision backend.",
  "scripts": {
    "dev": "vite --host localhost",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host localhost",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "test": "vitest run --coverage=false",
    "e2e": "playwright test",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build && npm run audit:prod",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@types/node": "25.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.0.0"
  }
}
